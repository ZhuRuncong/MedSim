# Copy to .env and fill in. Every value is OPTIONAL — the app runs fully
# offline/deterministic without any of these. They only unlock richer behaviour.

# --- LLM providers (enable AI case generation; either one works) ---
# Gemini:
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Anthropic Claude:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Force a provider ("gemini" | "anthropic"); blank = auto-select by key present.
MEDSIM_LLM_PROVIDER=

# --- AI case-generation safety knobs (generate-then-verify harness) ---
MEDSIM_GEN_MAX_ATTEMPTS=4
MEDSIM_GEN_VERIFIERS=2          # independent adversarial reviewers per case
MEDSIM_GEN_MIN_CONFIDENCE=0.7

# --- Grounded LLM agents (set to 1 to force deterministic behaviour) ---
MEDSIM_DISABLE_PATIENT_LLM=
MEDSIM_DISABLE_KNOWLEDGE_LLM=

# --- External knowledge lookup fallback ---
TAVILY_API_KEY=

# --- Vector store (embeddings for disease/drug semantic search) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Session persistence (falls back to in-process memory if unset) ---
REDIS_URL=

# --- Observability ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=medsim

# --- FastMCP / API gateway ---
MEDSIM_API_URL=http://localhost:8000
